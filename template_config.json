{
  "template_id": "ecommerce_after_sales",
  "name": "电商退款 / 售后工单汇总",
  "category": "互联网电商",
  "target_users": ["电商运营", "客服主管", "售后团队", "店铺负责人"],
  "required_fields": ["订单号", "商品", "售后类型", "退款原因", "处理状态", "退款金额"],
  "optional_fields": ["申请日期", "店铺", "渠道", "赔付金额", "响应时长", "处理时长", "客服", "备注"],
  "outputs": ["退换货趋势", "退款原因分布", "渠道售后汇总", "商品售后表现", "客服工单效率", "高风险工单", "问题清单", "经营诊断摘要"],
  "risk_rules": [
    {"name": "高金额退款", "condition": "退款金额 >= 1000"},
    {"name": "工单处理超时", "condition": "处理时长 > 48 且未完结"},
    {"name": "首次响应慢", "condition": "响应时长 > 12"},
    {"name": "退款原因缺失", "condition": "退款原因为空"}
  ]
}
